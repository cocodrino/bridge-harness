{
  "name": "@cocodrino/bridge-harness",
  "version": "0.1.3",
  "description": "Real-time NATS bridge for AI agent communication — connects Claude Code and Pi with zero user intervention",
  "type": "module",
  "author": "cocodrino",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cocodrino/bridge-harness.git"
  },
  "homepage": "https://github.com/cocodrino/bridge-harness#readme",
  "keywords": [
    "ai-agents",
    "claude-code",
    "pi-agent",
    "nats",
    "mcp",
    "multi-agent",
    "bridge"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "bridge-harness": "./dist/cli/index.js",
    "bridge-harness-mcp": "./dist/mcp-server/index.js",
    "bridge-harness-setup": "./dist/setup/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./nats-manager": "./dist/nats-manager/index.js",
    "./shared": "./dist/shared/index.js"
  },
  "files": [
    "dist/",
    "hooks/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "nats": "^2.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
